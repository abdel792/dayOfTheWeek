#. Translators: The long label of the days field.
#: addon\globalPlugins\DayOfTheWeek.py:47
msgid "You can select a day with the vertical arrows"
msgstr "Du kan vælge en dag med pil op og pil ned."

#. Translators: The short label of the days field.
#: addon\globalPlugins\DayOfTheWeek.py:49
msgid "Select a day"
msgstr "Vælg en dag"

#. Translators: The long label of the months field.
#: addon\globalPlugins\DayOfTheWeek.py:51
msgid "You can select a month with the vertical arrows"
msgstr "Du kan vælge en måned med pil op og pil ned."

#. Translators: The short label of the months field.
#: addon\globalPlugins\DayOfTheWeek.py:53
msgid "Select a month"
msgstr "Vælg en måned"

#. Translators: The long label of the years field.
#: addon\globalPlugins\DayOfTheWeek.py:55
msgid "You can select a year with the vertical arrows"
msgstr "Du kan vælge et år med pil op og pil ned."

#. Translators: The short label of the years field.
#: addon\globalPlugins\DayOfTheWeek.py:57
msgid "Select a year"
msgstr "Vælg et år"

#. Translators: The title of the Date Dialog.
#: addon\globalPlugins\DayOfTheWeek.py:108
#: addon\globalPlugins\DayOfTheWeek.py:589
msgid "Get the day of the week"
msgstr "Find ugedagen"

#. Translators: A label for a list in a dialog.
#: addon\globalPlugins\DayOfTheWeek.py:112
msgid "Type or select a date"
msgstr "Indtast eller vælg en dato"

#. Translators: The title of a dialog.
#: addon\globalPlugins\DayOfTheWeek.py:172
msgid "Your day"
msgstr "Din ugedag"

#. Translators: The title of the add-on configuration dialog box.
#: addon\globalPlugins\DayOfTheWeek.py:180
#, python-brace-format
msgid "Configuration of the addon {0}"
msgstr "Indstilling af tilføjelsesprogrammet {0}"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\DayOfTheWeek.py:183 buildVars.py:21
msgid "Day of the week"
msgstr "Ugedag"

#. Translators: Level for short announces of labels.
#: addon\globalPlugins\DayOfTheWeek.py:187
msgid "Short"
msgstr "Kort"

#. Translators: Level for long announces of labels.
#: addon\globalPlugins\DayOfTheWeek.py:190
msgid "Long"
msgstr "Lang"

#. Translators: Level to disable announces of labels.
#: addon\globalPlugins\DayOfTheWeek.py:193
msgid "Off"
msgstr "Fra"

#. Translators: The label of the checkbox to enable or disable the date selector accessibility.
#: addon\globalPlugins\DayOfTheWeek.py:198
msgid "En&able the accessibility of the date selector:"
msgstr "&Gør datovælgeren tilgængelig:"

#. Translators: The label for an item to select the level of the announces of labels.
#: addon\globalPlugins\DayOfTheWeek.py:200
msgid "Level of the announces of &labels:"
msgstr "Annonceringsniveau for &etiketter:"

#: addon\globalPlugins\DayOfTheWeek.py:203
msgid "Enable announcements of the current date field value only, when moving &vertically:"
msgstr "Annoncér kun det aktuelle datofelt, når der bevæges &lodret"

#. Translators: Item in the tools menu for the Addon dayOfTheWeek.
#: addon\globalPlugins\DayOfTheWeek.py:597
#: addon\globalPlugins\DayOfTheWeek.py:610
msgid "Day of the &week..."
msgstr "Uge&dag..."

#. Translators: The tooltyp text for the dayOfTheWeek item.
#. Translators: The tooltyp text for the first item in the dayOfTheWeek add-on submenu.
#: addon\globalPlugins\DayOfTheWeek.py:599
#: addon\globalPlugins\DayOfTheWeek.py:620
msgid "Search a day in the calendar"
msgstr "Find en dag i kalenderen"

#. Translators: The tooltyp text for the dayOfTheWeek submenu.
#: addon\globalPlugins\DayOfTheWeek.py:612
#, python-brace-format
msgid "{0} add-on and its settings"
msgstr "Tilføjelsesprogrammet {0} og dets indstillinger"

#. Translators: The name of the first item in the dayOfTheWeek add-on submenu.
#: addon\globalPlugins\DayOfTheWeek.py:618
msgid "Search a &day"
msgstr "Find en &dag"

#. Translators: The name of the second item in the dayOfTheWeek add-on submenu.
#: addon\globalPlugins\DayOfTheWeek.py:627
#, python-brace-format
msgid "{0} add-on se&ttings"
msgstr "&Indstillinger for tilføjelsesprogrammet {0}"

#. Translators: The tooltyp text for the second item in the dayOfTheWeek add-on submenu.
#: addon\globalPlugins\DayOfTheWeek.py:629
#, python-brace-format
msgid "Configure the {0} add-on"
msgstr "Indstil tilføjelsesprogrammet {0}"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\DayOfTheWeek.py:655
msgid "Allows you to find the day of the week corresponding to a chosen date."
msgstr "Lader dig finde den ugedag, som svarer til en valgt dato."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\DayOfTheWeek.py:664
#, python-brace-format
msgid "Allows you to open the {0} add-on settings dialog."
msgstr "Åbn dialogen Indstillinger for tilføjelsesprogrammet {0}."

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "With this add-on, you'll be able to find the day of the week corresponding to a chosen date."
msgstr "Med dette tilføjelsesprogram kan du finde den ugedag, som svarer til en valgt dato."

